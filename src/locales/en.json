  "help": {
    "title": "manyplug {{version}} - plugin manager for ManyBot",
    "unknownCommand": "unknown command: {{cmd}}",
    "runHelp": "run \"manyplug help\" for usage",
    "commandsLine": "commands: init install update link unlink remove search list enable disable validate version info",
