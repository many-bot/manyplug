    "commands": {
      "help":     { "description": "show help for a command" },
      "init":     {
        "description": "create new plugin, pluginpack, or profile boilerplate",
        "options": {
          "category": "category (integration games media utility admin fun moderation ai education social economy automation tools)",
          "type":     "plugin, pluginpack, or profile",
          "lang":     "plugin language: js or ts (prompted if omitted)"
        }
      },
      "install":  {
        "description": "install plugins, pluginpacks, or profiles from registry or local path",
        "options": {
          "local":  "install from local path",
          "watch":  "watch for changes and reinstall (requires --local)",
          "branch": "install from a specific branch",
          "yes":    "skip confirmation"
        }
      },
      "update":   {
        "description": "reinstall non-local plugins whose remote version changed (all if none given)",
        "options": { "yes": "skip confirmation", "force": "reinstall even if already up to date" }
      },
      "link":     { "description": "symlink a local plugin into the plugins dir (like npm link) — edits apply live, no reinstall needed" },
      "unlink":   {
        "description": "remove a linked plugin (undo link) — leaves the source directory untouched",
        "options": { "yes": "skip confirmation" }
      },
      "remove":   {
        "description": "remove installed plugins",
        "options": {
          "yes": "skip confirmation",
          "Y":   "skip confirmation even for plugin data"
        }
      },
      "search":   {
        "description": "search the registry for plugins",
        "options": { "category": "filter by category" }
      },
      "list":     {
        "description": "list installed plugins (enabled only by default)",
        "options": { "all": "include disabled plugins" }
      },
      "enable":   {
        "description": "enable plugins",
        "options": {
          "all":     "enable all plugins",
          "profile": "enable every plugin installed via this profile"
        }
      },
      "disable":  {
        "description": "disable plugins",
        "options": {
          "all":     "disable all plugins",
          "profile": "disable every plugin installed via this profile"
        }
      },
      "validate": { "description": "validate manyplug.json" },
      "version":  { "description": "apply a version to your plugin manifest (it can be any string)" },
      "info":     { "description": "show information about an installed plugin" }
    }
